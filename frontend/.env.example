# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# API base URLs — in local dev these are proxied through Vite (see vite.config.ts)
# In production set these to the actual API Gateway URLs
VITE_AUTH_API_URL=/api/auth
VITE_USERS_API_URL=/api/users
VITE_BOOKING_API_URL=/api/booking
VITE_ADMIN_API_URL=/api/admin

# Live estimator WebSocket — proxied through Vite in local dev; set to wss://... in production
VITE_LIVE_WS_URL=ws://localhost:3105
