#!/bin/sh
# Pre-commit: unit → integration → E2E
# All three must pass before a commit is accepted.
#
# Integration tests require Docker Postgres:   npm run db:up
# E2E tests require the Vite dev server or will start one automatically.

set -e

echo ""
echo "╔══════════════════════════════════════╗"
echo "║        Pre-commit test suite         ║"
echo "╚══════════════════════════════════════╝"

# ── 1. Unit tests (fast, no deps) ────────────────────────────────────────────
echo ""
echo "▶ Unit tests…"
npm test --silent
echo "✅ Unit tests passed"

# ── 2. Integration tests (requires Docker Postgres) ───────────────────────────
echo ""
echo "▶ Integration tests…"
if ! npm run test:integration --silent 2>&1; then
  echo ""
  echo "❌ Integration tests failed."
  echo "   Is Docker Postgres running?  →  npm run db:up"
  exit 1
fi
echo "✅ Integration tests passed"

# ── 3. E2E tests (Playwright — starts Vite if not already running) ────────────
echo ""
echo "▶ E2E tests…"
if ! npm run test:e2e 2>&1; then
  echo ""
  echo "❌ E2E tests failed. Run  npx playwright test --ui  to debug."
  exit 1
fi
echo "✅ E2E tests passed"

echo ""
echo "✅ All tests passed — committing."
echo ""
